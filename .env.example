# Copy to .env and adjust for local dev. Real secrets never get committed.

# Django
DJANGO_SECRET_KEY=dev-secret-change-me-please-32-bytes-minimum
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend
DJANGO_LOG_LEVEL=INFO

# Postgres
POSTGRES_DB=retail_analytics
POSTGRES_USER=retail_analytics
POSTGRES_PASSWORD=retail_analytics
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Redis / Celery (same Redis instance serves both in Phase 1)
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Frontend dev server -> backend proxy target
VITE_API_PROXY_TARGET=http://backend:8000

# Object storage (MinIO in dev; Cloudflare R2 / Backblaze B2 in prod, same S3 API)
OBJECT_STORAGE_ENDPOINT_URL=http://minio:9000
OBJECT_STORAGE_ACCESS_KEY=minioadmin
OBJECT_STORAGE_SECRET_KEY=minioadmin
OBJECT_STORAGE_BUCKET=retail-analytics-uploads
OBJECT_STORAGE_REGION=auto
