# Copy to .env on the production host and fill in every placeholder below
# before running:
#   docker compose -f docker-compose.yml -f docker-compose.prod.yml up -d --build
# Real secrets never get committed -- this file only documents the shape.

# Django
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=REPLACE_ME_generate_a_real_random_secret
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=your-domain.example.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://your-domain.example.com
DJANGO_LOG_LEVEL=WARNING
# Once TLS is confirmed working end-to-end (see ops/runbooks/deploy.md),
# flip these on. Leave DJANGO_SECURE_HSTS_SECONDS at 0 until then --
# HSTS is cached by browsers and hard to undo if TLS turns out broken.
DJANGO_SECURE_SSL_REDIRECT=true
DJANGO_SECURE_HSTS_SECONDS=31536000

# Postgres -- use a real generated password, not this placeholder
POSTGRES_DB=retail_analytics
POSTGRES_USER=retail_analytics
POSTGRES_PASSWORD=REPLACE_ME_generate_a_real_password
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Redis / Celery (same Redis instance serves both in Phase 1)
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# gunicorn workers -- a reasonable starting point is (2 x CPU cores) + 1
GUNICORN_WORKERS=4

# Caddy reverse proxy + automatic TLS (see ops/caddy/Caddyfile) -- must be
# a real public domain with DNS A/AAAA records already pointed at this
# host's IP before Caddy can obtain a Let's Encrypt certificate.
DOMAIN=your-domain.example.com

# Object storage -- self-hosted MinIO (default below, same as dev, just
# with real generated credentials) or an external S3-compatible provider
# (Cloudflare R2 / Backblaze B2 -- same client code, only these values
# change, see backend/apps/ingestion/storage.py). Also used by
# `manage.py backup_database` for nightly DB dump storage (see
# ops/runbooks/restore.md), under the same bucket's backups/ prefix.
OBJECT_STORAGE_ENDPOINT_URL=http://minio:9000
OBJECT_STORAGE_ACCESS_KEY=REPLACE_ME_generate_real_credentials
OBJECT_STORAGE_SECRET_KEY=REPLACE_ME_generate_real_credentials
OBJECT_STORAGE_BUCKET=retail-analytics-uploads
OBJECT_STORAGE_REGION=auto

# Backup retention -- how many days of nightly backups to keep in object
# storage before older ones are deleted (see manage.py backup_database).
BACKUP_RETENTION_DAYS=14
