# Production reverse proxy + TLS. Caddy auto-provisions and renews a
# Let's Encrypt certificate for {$DOMAIN} the first time it's reachable on
# ports 80/443 from the internet -- no certbot dance, no manual renewal
# cron. If DOMAIN isn't a public hostname yet (unset, "localhost", a bare
# IP), Caddy transparently falls back to its own internal CA instead of
# attempting Let's Encrypt, which is what makes this exact file testable
# locally before a real domain exists.
#
# default_sni matters specifically for the bare-IP case: SNI only applies
# to hostnames (RFC 6066), so a client connecting straight to an IP sends
# no SNI at all. Caddy's fallback is to match the connection's *local
# socket address* instead -- which works on a plain VPS, but not behind a
# cloud NAT (e.g. AWS Elastic IP): the instance's own OS only ever sees
# its private IP, never the public one the cert was actually issued for,
# so the handshake fails with "no certificate available for <private
# IP>". Telling Caddy what SNI to assume when none is given sidesteps
# that local-address lookup entirely. Harmless once a real domain is set
# -- real hostnames always send SNI, so this default is simply never used.
{
	default_sni {$DOMAIN}
}

{$DOMAIN} {
	encode gzip

	# Django admin's CSS/JS: gunicorn doesn't serve STATIC_ROOT itself, so
	# entrypoint.sh runs collectstatic into a volume Caddy serves directly
	# -- handle_path strips the /static prefix to match STATIC_ROOT's
	# on-disk layout (STATIC_URL is "static/").
	handle_path /static/* {
		root * /srv/static
		file_server
	}

	@backend path /api/* /admin/* /health/*
	handle @backend {
		reverse_proxy backend:8000
	}

	handle {
		root * /srv/frontend
		try_files {path} /index.html
		file_server
	}
}
